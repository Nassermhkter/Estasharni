{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for clients, doctors, and admins",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "doctor", "admin"] },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "DoctorProfile": {
      "title": "Doctor Profile",
      "description": "Detailed professional information for doctors",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "specialty": { "type": "string" },
        "qualifications": { "type": "string" },
        "experience": { "type": "string" },
        "certificates": { "type": "array", "items": { "type": "string" } },
        "bio": { "type": "string" },
        "availability": { "type": "object" },
        "approvalStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" }
      },
      "required": ["userId", "specialty", "approvalStatus"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "Medical consultation request between client and doctor",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "status": { "type": "string", "enum": ["requested", "scheduled", "completed", "cancelled"] },
        "requestDate": { "type": "string", "format": "date-time" },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "subject": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["clientId", "doctorId", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Messages for consultations or support",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "consultationId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "file"] },
        "url": { "type": "string" }
      },
      "required": ["senderId", "receiverId", "content", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time alerts for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "body", "read", "createdAt"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Platform settings",
      "type": "object",
      "properties": {
        "platformName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "maintenanceMode": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Main user collection"
    },
    "doctors/{doctorId}": {
      "schema": "DoctorProfile",
      "description": "Professional profiles linked to users"
    },
    "consultations/{consultationId}": {
      "schema": "Consultation",
      "description": "Consultation sessions"
    },
    "consultations/{consultationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat transcript for a consultation"
    },
    "support_messages/{messageId}": {
      "schema": "Message",
      "description": "Messages to administration"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "settings/general": {
      "schema": "Setting",
      "description": "Global settings"
    }
  }
}
