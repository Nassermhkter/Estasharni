{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users including patients, doctors, and admins.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Medical professionals profiles.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "string" },
        "qualifications": { "type": "string" },
        "bio": { "type": "string" },
        "photo": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rating": { "type": "number" },
        "createdAt": { "type": "string" }
      }
    },
    "Consultation": {
      "title": "Consultation",
      "description": "Medical consultation requests.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed"] },
        "createdAt": { "type": "string" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Contact form submissions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "ChatUser": {
      "title": "ChatUser",
      "description": "Index for active chats.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastTime": { "type": "string" },
        "unread": { "type": "number" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Individual messages in a chat.",
      "type": "object",
      "properties": {
        "from": { "type": "string", "enum": ["user", "admin"] },
        "fromName": { "type": "string" },
        "text": { "type": "string" },
        "time": { "type": "string" }
      }
    },
    "Admin": {
      "title": "Admin",
      "description": "Administrative users.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "level": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "Setting": {
      "title": "Setting",
      "description": "Platform settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "link": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Global users collection" },
    "/doctors/{doctorId}": { "schema": "Doctor", "description": "Doctor profiles" },
    "/consultations/{consultId}": { "schema": "Consultation", "description": "Consultation requests" },
    "/messages/{messageId}": { "schema": "Message", "description": "Contact messages" },
    "/chatUsers/{userId}": { "schema": "ChatUser", "description": "Chat metadata index" },
    "/chats/{userId}/messages/{msgId}": { "schema": "ChatMessage", "description": "Chat messages per user" },
    "/admins/{userId}": { "schema": "Admin", "description": "Restricted admin roles" },
    "/settings/general": { "schema": "Setting", "description": "System configuration" },
    "/notifications/{notifId}": { "schema": "Notification", "description": "User notifications" }
  }
}
