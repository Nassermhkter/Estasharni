rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'hadirynasser@gmail.com' ||
        request.auth.token.email == 'hadirynaser@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.role in ['patient', 'doctor', 'admin'] &&
                    request.resource.data.email == request.auth.token.email;
      allow update: if isAdmin() || isOwner(userId);
    }

    // Doctors
    match /doctors/{doctorId} {
      allow read: if true; // Public profiles
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Consultations
    match /consultations/{consultId} {
      allow read, list: if isAdmin() || (isSignedIn() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid));
    }

    // Messages (Contact form)
    match /messages/{messageId} {
      allow create: if true; // Public can send messages
      allow read, list: if isAdmin();
    }

    // Chat Metadata Index
    match /chatUsers/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Chat Messages
    match /chats/{userId}/messages/{msgId} {
      allow read, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
    }

    // Admins (Restricted access to roles)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && (request.auth.token.email == 'hadirynasser@gmail.com' || request.auth.token.email == 'hadirynaser@gmail.com'));
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin(); // Only system/admin typically creates notifications
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
