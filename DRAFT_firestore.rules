rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // H1: Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // H2: Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isSignedIn() && getUserData().role == 'admin'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // -------------------------------------------------------------------------
    // H3: Entity Validations
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) 
        && data.uid == request.auth.uid 
        && data.role in ['client', 'doctor', 'admin']
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.email is string && data.email.size() <= 100);
    }

    function isValidDoctorProfile(data) {
      return data.keys().hasAll(['userId', 'specialty', 'approvalStatus'])
        && data.userId == request.auth.uid
        && data.specialty is string && data.specialty.size() <= 100
        && data.approvalStatus in ['pending', 'approved', 'rejected']
        && (data.qualifications is string && data.qualifications.size() <= 2000)
        && (data.experience is string && data.experience.size() <= 2000);
    }

    // -------------------------------------------------------------------------
    // R1: Users Collection
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      // On creation, users can set their role but role changes are restricted
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming())
                   && (incoming().role == 'client' || incoming().role == 'doctor');
      // Role can only be changed by admin
      allow update: if (isSignedIn() && isOwner(userId) && isValidUser(incoming()) 
                     && incoming().role == existing().role
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'updatedAt']))
                  || isAdmin();
    }

    // -------------------------------------------------------------------------
    // R2: Doctors Profile Collection (Public for approved)
    // -------------------------------------------------------------------------
    match /doctors/{doctorId} {
      allow read: if (existing().approvalStatus == 'approved') || isAdmin() || isOwner(doctorId);
      allow create: if isSignedIn() && isOwner(doctorId) 
                   && getUserData().role == 'doctor'
                   && isValidDoctorProfile(incoming())
                   && incoming().approvalStatus == 'pending';
      allow update: if (isOwner(doctorId) 
                     && isValidDoctorProfile(incoming())
                     && incoming().approvalStatus == existing().approvalStatus // Only admin changes Status
                     && incoming().diff(existing()).affectedKeys().hasOnly(['specialty', 'qualifications', 'experience', 'availability', 'bio']))
                  || (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['approvalStatus', 'rejectionReason']));
    }

    // -------------------------------------------------------------------------
    // R3: Consultations
    // -------------------------------------------------------------------------
    match /consultations/{consultationId} {
      allow read: if isSignedIn() && (isOwner(existing().clientId) || isOwner(existing().doctorId) || isAdmin());
      allow create: if isSignedIn() 
                   && isOwner(incoming().clientId)
                   && get(/databases/$(database)/documents/doctors/$(incoming().doctorId)).data.approvalStatus == 'approved'
                   && incoming().status == 'requested';
      allow update: if isSignedIn() && (isOwner(existing().clientId) || isOwner(existing().doctorId) || isAdmin())
                   && incoming().clientId == existing().clientId
                   && incoming().doctorId == existing().doctorId
                   && (
                     // Doctor accepts or reschedules
                     (isOwner(existing().doctorId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'scheduledTime', 'notes']))
                     || // Client cancels
                     (isOwner(existing().clientId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes']))
                     || // Admin full update
                     isAdmin()
                   );
    }

    // -------------------------------------------------------------------------
    // R4: Contextual Messages (Subcollection of consultations)
    // -------------------------------------------------------------------------
    match /consultations/{consultationId}/messages/{messageId} {
      // Must fetch consultation to verify membership
      function getConsultation() { return get(/databases/$(database)/documents/consultations/$(consultationId)).data; }
      allow read: if isSignedIn() && (isOwner(getConsultation().clientId) || isOwner(getConsultation().doctorId) || isAdmin());
      allow create: if isSignedIn() && (isOwner(getConsultation().clientId) || isOwner(getConsultation().doctorId))
                   && incoming().senderId == request.auth.uid
                   && incoming().content.size() <= 5000;
    }

    // -------------------------------------------------------------------------
    // R5: Support Messages
    // -------------------------------------------------------------------------
    match /support_messages/{messageId} {
      allow read: if isSignedIn() && (isOwner(existing().senderId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().senderId) && incoming().content.size() <= 5000;
      allow update: if isAdmin(); // Admin replies
    }

    // -------------------------------------------------------------------------
    // R6: Notifications
    // -------------------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && isOwner(existing().userId);
      allow update: if isSignedIn() && isOwner(existing().userId) 
                   && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin(); // Only system/admin creates notifications
    }

    // -------------------------------------------------------------------------
    // R7: Settings
    // -------------------------------------------------------------------------
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
